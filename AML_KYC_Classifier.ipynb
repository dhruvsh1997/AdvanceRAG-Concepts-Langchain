    "    (\"T018\", \"C002\", \"20,000\",    \"2026-03-02 18:00\", \"Food\",       \"Chennai\",      \"NORMAL\",            \"NONE\"),\n",
    "    (\"T019\", \"C002\", \"1,30,000\",  \"2026-03-02 09:00\", \"Jewellery\",  \"Delhi\",        \"AMBIGUOUS INPUT\",   \"Dup timestamp with T003\"),\n",
