    "\n",
    "# ── Option A: paste your key directly (not recommended for shared notebooks)\n",
    "# os.environ[\"OPENAI_API_KEY\"] = \"sk-...\"\n",
    "\n",
    "# ── Option B: use Colab Secrets (recommended)\n",
    "# 1. Click the 🔑 icon in the left sidebar\n",
    "# 2. Add a secret named OPENAI_API_KEY with your key value\n",
    "# 3. Toggle the access switch ON for this notebook\n",
    "try:\n",
