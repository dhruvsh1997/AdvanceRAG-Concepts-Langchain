    "from collections import defaultdict\n",
    "\n",
    "def customer_summary(transactions: list, parsed: dict, profiles: dict):\n",
    "    \"\"\"Groups classification results by customer for a compliance-style summary.\"\"\"\n",
    "    \n",
    "    by_customer = defaultdict(list)\n",
    "    for txn in transactions:\n",
    "        txn_id, cust_id = txn[0], txn[1]\n",
    "        result = parsed.get(txn_id, {}).get(\"result\", \"NOT FOUND\")\n",
    "        rules  = parsed.get(txn_id, {}).get(\"rules\", \"\")\n",
    "        by_customer[cust_id].append((txn_id, result, rules))\n",
    "\n",
    "    print(\"═\" * 65)\n",
    "    print(\"CUSTOMER-LEVEL COMPLIANCE SUMMARY\")\n",
    "    print(\"═\" * 65)\n",
    "\n",
    "    for cust_id, txn_list in sorted(by_customer.items()):\n",
    "        profile = profiles.get(cust_id, {})\n",
    "        name    = profile.get(\"name\", \"Unknown\")\n",
    "        kyc     = profile.get(\"kyc\", \"Unknown\")\n",
    "        risk    = profile.get(\"risk\", \"Unknown\")\n",
    "        account = profile.get(\"account\", \"Unknown\")\n",
    "\n",
    "        suspicious = [t for t in txn_list if t[1] == \"SUSPICIOUS\"]\n",
    "        normal     = [t for t in txn_list if t[1] == \"NORMAL\"]\n",
    "        invalid    = [t for t in txn_list if t[1] in (\"INSUFFICIENT DATA\", \"AMBIGUOUS INPUT\")]\n",
    "\n",
    "        flag = \"🔴\" if suspicious else (\"🟡\" if kyc == \"Pending\" else \"🟢\")\n",
    "\n",
    "        print(f\"\\n{flag} {cust_id} — {name} | {account} | KYC: {kyc} | Risk: {risk}\")\n",
    "        print(f\"   Total txns   : {len(txn_list)}\")\n",
    "        print(f\"   Suspicious   : {len(suspicious)} {[t[0] for t in suspicious]}\")\n",
    "        print(f\"   Normal       : {len(normal)} {[t[0] for t in normal]}\")\n",
    "        print(f\"   Invalid/Ambig: {len(invalid)} {[t[0] for t in invalid]}\")\n",
    "\n",
    "        if suspicious:\n",
    "            all_rules = set()\n",
    "            for _, _, rules in suspicious:\n",
    "                for r in rules.split(\",\"):\n",
    "                    r = r.strip()\n",
    "                    if r and r != \"NONE\":\n",
    "                        all_rules.add(r)\n",
    "            print(f\"   Rules fired  : {', '.join(sorted(all_rules))}\")\n",
    "\n",
    "    print(\"\\n\" + \"═\" * 65)\n",
    "    all_suspicious_count = sum(\n",
    "        1 for _, info in parsed.items() if info[\"result\"] == \"SUSPICIOUS\"\n",
    "    )\n",
    "    print(f\"TOTAL SUSPICIOUS TRANSACTIONS: {all_suspicious_count}\")\n",
    "\n",
    "\n",
    "customer_summary(TRANSACTIONS, parsed_results, CUSTOMER_PROFILES)"
   ]
