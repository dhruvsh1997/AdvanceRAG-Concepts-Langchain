   "source": [
    "## Cell 5 — Core API Call Helper + Single Transaction Tester"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def build_user_message(transactions: list, customer_profiles: dict) -> str:\n",
    "    \"\"\"\n",
    "    Builds the user message with all transactions to classify.\n",
    "    Sends ALL transactions in one shot so the model can pre-compute R2 correctly.\n",
    "    \"\"\"\n",
    "    lines = []\n",
    "    lines.append(\"Classify the following transactions. All transactions are listed below.\")\n",
    "    lines.append(\"Apply R2 pre-computation across ALL transactions before evaluating any individually.\")\n",
    "    lines.append(\"\")\n",
    "    lines.append(\"TRANSACTION LIST:\")\n",
    "    lines.append(\"-\" * 60)\n",
    "\n",
    "    for txn in transactions:\n",
    "        txn_id, cust_id, amount, timestamp, category, location = txn[:6]\n",
    "        profile = customer_profiles.get(cust_id, {})\n",
    "        kyc = profile.get(\"kyc\", \"UNKNOWN\")\n",
    "        risk = profile.get(\"risk\", \"UNKNOWN\")\n",
    "\n",
    "        lines.append(f\"Txn_ID           : {txn_id}\")\n",
    "        lines.append(f\"Customer_ID      : {cust_id}\")\n",
    "        lines.append(f\"Amount (₹)       : {amount}\")\n",
    "        lines.append(f\"Timestamp        : {timestamp}\")\n",
    "        lines.append(f\"Merchant_Category: {category}\")\n",
    "        lines.append(f\"Location         : {location}\")\n",
    "        lines.append(f\"KYC_Status       : {kyc}\")\n",
    "        lines.append(f\"Risk_Profile     : {risk}\")\n",
    "        lines.append(\"-\" * 60)\n",
    "\n",
    "    return \"\\n\".join(lines)\n",
    "\n",
    "\n",
    "def classify_transactions(transactions: list, customer_profiles: dict,\n",
    "                           temperature: float = 0.0, verbose: bool = True) -> str:\n",
    "    \"\"\"\n",
    "    Sends transactions to OpenAI and returns the raw model output.\n",
    "    temperature=0.0 ensures deterministic/reproducible outputs.\n",
    "    \"\"\"\n",
    "    user_msg = build_user_message(transactions, customer_profiles)\n",
    "\n",
    "    if verbose:\n",
    "        print(\"📤 Sending request to OpenAI...\")\n",
    "        print(f\"   Transactions: {len(transactions)}\")\n",
    "        print(f\"   Model: {MODEL} | Temperature: {temperature}\")\n",
    "        print()\n",
    "\n",
    "    response = client.chat.completions.create(\n",
    "        model=MODEL,\n",
    "        temperature=temperature,\n",
    "        messages=[\n",
    "            {\"role\": \"system\", \"content\": SYSTEM_PROMPT},\n",
    "            {\"role\": \"user\",   \"content\": user_msg},\n",
    "        ]\n",
    "    )\n",
    "\n",
    "    return response.choices[0].message.content\n",
    "\n",
    "\n",
    "# ── Quick single transaction test ──\n",
    "# Test T017 (C001, ₹2,00,000, Dubai) — should fire R1, R2, R3 simultaneously\n",
    "test_txn = [t for t in TRANSACTIONS if t[0] == \"T017\"]\n",
    "\n",
    "print(\"━\" * 60)\n",
    "print(\"SINGLE TRANSACTION TEST: T017 (expected: R1 + R2 + R3)\")\n",
    "print(\"━\" * 60)\n",
    "\n",
    "result = classify_transactions(test_txn, CUSTOMER_PROFILES)\n",
    "print(result)"
   ]
