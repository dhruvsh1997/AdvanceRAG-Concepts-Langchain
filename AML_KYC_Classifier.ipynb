    "## Cell 7 — Parse Output + Compare Against Expected Results"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import re\n",
    "\n",
    "def parse_results_from_output(raw_output: str) -> dict:\n",
    "    \"\"\"\n",
    "    Parses the model's plain-text output blocks into a dict keyed by Txn_ID.\n",
    "    Extracts: Customer ID, Transactions, Result, Rules Triggered, Explanation.\n",
    "    \"\"\"\n",
    "    results = {}\n",
    "\n",
    "    # Split on the ════ OUTPUT ════ delimiter\n",
    "    blocks = re.split(r'={40,}\\s*OUTPUT\\s*={40,}', raw_output)\n",
    "    \n",
    "    for block in blocks:\n",
    "        block = block.strip()\n",
    "        if not block:\n",
    "            continue\n",
    "\n",
    "        # Extract Txn IDs from \"Transactions\" field\n",
    "        txn_match = re.search(r'2\\.\\s*Transactions\\s*:\\s*(.+)', block)\n",
    "        if not txn_match:\n",
    "            continue\n",
    "        txn_ids = [t.strip() for t in txn_match.group(1).split(\",\")]\n",
    "\n",
    "        # Extract classification result\n",
    "        result_match = re.search(\n",
    "            r'Result:\\s*(SUSPICIOUS|NORMAL|INSUFFICIENT DATA|AMBIGUOUS INPUT)', block\n",
    "        )\n",
    "        result = result_match.group(1) if result_match else \"NOT FOUND\"\n",
    "\n",
    "        # Extract rules triggered\n",
    "        rules_match = re.search(r'7\\.\\s*Rules Triggered\\s*:\\s*(.+)', block)\n",
    "        rules = rules_match.group(1).strip() if rules_match else \"NOT FOUND\"\n",
    "\n",
    "        # Extract explanation\n",
    "        exp_match = re.search(r'8\\.\\s*Explanation\\s*:\\s*(.+?)(?=\\n\\n|\\Z)', block, re.DOTALL)\n",
    "        explanation = exp_match.group(1).strip() if exp_match else \"\"\n",
    "\n",
    "        for txn_id in txn_ids:\n",
    "            results[txn_id] = {\n",
    "                \"result\": result,\n",
    "                \"rules\": rules,\n",
    "                \"explanation\": explanation,\n",
    "            }\n",
    "\n",
    "    return results\n",
    "\n",
    "\n",
    "def compare_results(transactions: list, parsed: dict):\n",
    "    \"\"\"Prints a pass/fail comparison table.\"\"\"\n",
    "    GREEN = \"\\033[92m\"\n",
    "    RED   = \"\\033[91m\"\n",
    "    RESET = \"\\033[0m\"\n",
    "    BOLD  = \"\\033[1m\"\n",
    "\n",
    "    print(f\"{BOLD}{'TXN':<6} {'CUST':<6} {'EXPECTED':<20} {'ACTUAL':<20} {'STATUS'}{RESET}\")\n",
    "    print(\"-\" * 72)\n",
    "\n",
    "    passed = 0\n",
    "    failed = 0\n",
    "    missing = 0\n",
    "\n",
    "    for txn in transactions:\n",
    "        txn_id, cust_id = txn[0], txn[1]\n",
    "        expected = txn[6]   # Expected Result column\n",
    "        expected_rules = txn[7]\n",
    "\n",
    "        if txn_id not in parsed:\n",
    "            print(f\"{txn_id:<6} {cust_id:<6} {expected:<20} {'[NOT IN OUTPUT]':<20} {RED}⚠ MISSING{RESET}\")\n",
    "            missing += 1\n",
    "            continue\n",
    "\n",
    "        actual = parsed[txn_id][\"result\"]\n",
    "\n",
    "        # Normalize for comparison (INSUFFICIENT DATA vs INSUFFICIENT DATA)\n",
    "        exp_norm = expected.strip().upper()\n",
    "        act_norm = actual.strip().upper()\n",
    "\n",
    "        if exp_norm == act_norm:\n",
    "            status = f\"{GREEN}✅ PASS{RESET}\"\n",
    "            passed += 1\n",
    "        else:\n",
    "            status = f\"{RED}❌ FAIL{RESET}\"\n",
    "            failed += 1\n",
    "\n",
    "        print(f\"{txn_id:<6} {cust_id:<6} {expected:<20} {actual:<20} {status}\")\n",
    "\n",
    "    print(\"-\" * 72)\n",
    "    total = len(transactions)\n",
    "    print(f\"\\n📊 Results: {passed}/{total} passed  |  {failed} failed  |  {missing} missing\")\n",
    "    accuracy = (passed / total) * 100\n",
    "    print(f\"🎯 Accuracy: {accuracy:.1f}%\")\n",
    "\n",
    "\n",
    "# Run comparison\n",
    "parsed_results = parse_results_from_output(FULL_OUTPUT)\n",
    "\n",
    "print(\"━\" * 72)\n",
    "print(\"CLASSIFICATION ACCURACY REPORT\")\n",
    "print(\"━\" * 72)\n",
    "compare_results(TRANSACTIONS, parsed_results)\n",
    "\n",
    "print(\"\\n\" + \"━\" * 72)\n",
    "print(\"DETAILED RESULTS WITH RULES\")\n",
    "print(\"━\" * 72)\n",
    "for txn_id, info in parsed_results.items():\n",
    "    print(f\"\\n{txn_id}:\")\n",
    "    print(f\"  Result : {info['result']}\")\n",
    "    print(f\"  Rules  : {info['rules']}\")\n",
    "    if info['explanation']:\n",
    "        print(f\"  Explain: {info['explanation'][:120]}...\" if len(info['explanation']) > 120 else f\"  Explain: {info['explanation']}\")"
   ]
  },
